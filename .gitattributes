# Normalizar finales de línea y encoding automáticamente
* text=auto eol=lf

# Archivos JavaScript y React
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# HTML
*.html text eol=lf

# Markdown
*.md text eol=lf

# Archivos binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
